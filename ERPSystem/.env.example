# I'M NOT GONNA TELL YOU HOW TO DEAL WITH A .env.example FILE but anyways

# This file serves as a template for environment variable configuration in the ERP system.
# It includes placeholders and examples for database connection strings, service URLs, and security settings.
# To use, copy this file to .env and update the values according to your environment (development, staging, production).
# Remember: Never commit the .env file to version control, as it may contain sensitive information such as passwords and API keys.

# ============================================
# ERP SYSTEM ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update values
# Never commit .env to version control!

# ============================================
# DATABASE CONFIGURATION
# ============================================

# ── SQL Server (All Services) ─────────────────
# Password for SA account (must meet SQL Server complexity requirements)
# Minimum: 8 characters, with uppercase, lowercase, numbers, and symbols
SQLSERVER__SA_PASSWORD=YourStrong!Passw0rd123

# Connection Strings (used by individual services), put these en each .env file of each service, or use environment-specific variables as shown below
# Development (local): use appsettings.Development.json connection strings or override here

# Docker (container-to-container communication)
CONNECTIONSTRING__ERPUSERSDB_DOCKER=Server=sqlserver;Database=ERPUsersDb;User Id=sa;Password=${SQLSERVER__SA_PASSWORD};TrustServerCertificate=True;
CONNECTIONSTRING__ERPCLIENTSDB_DOCKER=Server=sqlserver;Database=ERPClientsDb;User Id=sa;Password=${SQLSERVER__SA_PASSWORD};TrustServerCertificate=True;
CONNECTIONSTRING__ERPSTOCKDB_DOCKER=Server=sqlserver;Database=ERPStockDb;User Id=sa;Password=${SQLSERVER__SA_PASSWORD};TrustServerCertificate=True;

# ── MongoDB (AuthService) ─────────────────────
MONGO__CONNECTIONSTRING=mongodb://user:password@mongo:27017
MONGO__DATABASENAME=ERPAuthDb
MONGO__USERNAME=erp_user
MONGO__PASSWORD=your_mongo_password_here

# ============================================
# SERVICE DISCOVERY & COMMUNICATION
# ============================================

# ── Kafka (Event Bus) ────────────────────────
KAFKA__BOOTSTRAPSERVERS=kafka:9092
# Optional: Kafka security settings
# KAFKA__SASL_USERNAME=
# KAFKA__SASL_PASSWORD=

# ── Service URLs (Docker Mode) ───────────────
SERVICE__AUTH_URL=http://erp-auth:8080
SERVICE__CLIENT_URL=http://erp-client:8080
SERVICE__STOCK_URL=http://erp-stock:8080
SERVICE__ARTICLE_URL=http://erp-article:8080
SERVICE__GATEWAY_URL=http://erp-gateway:8080

# Service URLs (Development Mode)
SERVICE__AUTH_URL_DEV=http://localhost:5001
SERVICE__CLIENT_URL_DEV=http://localhost:5003
SERVICE__STOCK_URL_DEV=http://localhost:5004
SERVICE__ARTICLE_URL_DEV=http://localhost:5002
SERVICE__GATEWAY_URL_DEV=http://localhost:5000

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

# ── JWT (Shared between Gateway and AuthService) ──
# Generate a strong secret: openssl rand -base64 32
JWT__SECRET=your-256-bit-secret-key-with-at-least-32-characters
JWT__ISSUER=ERP.AuthService
JWT__AUDIENCE=ERP.Clients
JWT__EXPIRATION_MINUTES=60

# ── API Keys (if applicable on external apis, eg: api.pwnedpasswords.com for password breaches) ─────────────────
# API_KEY__SERVICE_TO_SERVICE=your-api-key-here
