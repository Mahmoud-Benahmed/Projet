{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ERP_PaymentDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Services": {
    "InvoiceService": {
      "BaseUrl": "http://erp-invoice-service:5037"
    },
    "ClientService": {
      "BaseUrl": "http://localhost:5157"
    }
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "ConsumerGroups": {
      "PaymentDecision": "payment-service-decision"
    }
  }
}
