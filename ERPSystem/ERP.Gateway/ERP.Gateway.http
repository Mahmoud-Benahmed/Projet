@categoryId    = 7260DD52-F8B9-4537-B976-189F79C6591A
@articleCode   = ART-2026-000020

# ===========================================
# BLOCK 1 — NO TOKEN → always 401

### 401 — no token
GET {{gateway}}/articles

### 401 — tampered token
GET {{gateway}}/articles
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.tampered.signature

# ===========================================
# BLOCK 2 — SYSTEMADMIN → all 200
# ===========================================

### ✅ 200
GET {{gateway}}/articles
Authorization: Bearer {{adminToken}}

### ✅ 200
GET {{gateway}}/articles/{{articleId}}
Authorization: Bearer {{adminToken}}

### ✅ 200
GET {{gateway}}/articles/by-code/{{articleCode}}
Authorization: Bearer {{adminToken}}

### ✅ 200
GET {{gateway}}/articles/paged/by-category?categoryId={{categoryId}}&pageNumber=1&pageSize=5
Authorization: Bearer {{adminToken}}

### ✅ 200
GET {{gateway}}/articles/paged/by-status?isActive=true&pageNumber=1&pageSize=5
Authorization: Bearer {{adminToken}}

### ✅ 200
GET {{gateway}}/articles/paged/by-libelle?libelleFilter=écran&pageNumber=1&pageSize=5
Authorization: Bearer {{adminToken}}

### ✅ 201
POST {{gateway}}/articles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{ "libelle": "Admin Test Article", "prix": 99.99, "categoryId": "{{categoryId}}" }

### ✅ 200
PUT {{gateway}}/articles/{{articleId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{ "libelle": "Updated by Admin", "prix": 149.99, "categoryId": "{{categoryId}}" }

### ✅ 200
PATCH {{gateway}}/articles/{{articleId}}/deactivate
Authorization: Bearer {{adminToken}}

### ✅ 200
PATCH {{gateway}}/articles/{{articleId}}/activate
Authorization: Bearer {{adminToken}}

### ✅ 204
DELETE {{gateway}}/articles/{{articleId}}
Authorization: Bearer {{adminToken}}

# ===========================================
# BLOCK 3 — SALESMANAGER → view only
# ===========================================

### ✅ 200 — SalesManager has ViewArticles
GET {{gateway}}/articles
Authorization: Bearer {{salesToken}}

### ✅ 200 — SalesManager has ViewArticles
GET {{gateway}}/articles/{{articleId}}
Authorization: Bearer {{salesToken}}

### ✅ 200 — SalesManager has ViewArticles
GET {{gateway}}/articles/paged/by-status?isActive=true&pageNumber=1&pageSize=5
Authorization: Bearer {{salesToken}}

### ❌ 403 — SalesManager does NOT have CreateArticle
POST {{gateway}}/articles
Authorization: Bearer {{salesToken}}
Content-Type: application/json

{ "libelle": "Sales Test Article", "prix": 99.99, "categoryId": "{{categoryId}}" }

### ❌ 403 — SalesManager does NOT have UpdateArticle
PUT {{gateway}}/articles/{{articleId}}
Authorization: Bearer {{salesToken}}
Content-Type: application/json

{ "libelle": "Sales Update", "prix": 149.99, "categoryId": "{{categoryId}}" }

### ❌ 403 — SalesManager does NOT have UpdateArticle
PATCH {{gateway}}/articles/{{articleId}}/activate
Authorization: Bearer {{salesToken}}

### ❌ 403 — SalesManager does NOT have DeleteArticle
DELETE {{gateway}}/articles/{{articleId}}
Authorization: Bearer {{salesToken}}

